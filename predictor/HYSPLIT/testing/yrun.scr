#!/bin/bash
#
# yrun.scr --- run test scripts in the HYSPLIT tutorial
#
# This script can take up to 4 optional comman-line arguments.
#
# Usage: yrun.scr [TUTORIAL_DIR] [HYSPLIT_DIR] [OUTPUT_DIR] [CPU_COUNT]
#
# 19 Sep 2022 (SYZ) - initial
# 11 Oct 2022 (SYZ) - create plot files for Secs. 10.4, 10.5, and 10.6.
#                     check if required HYSPLIT executables are present.
#  3 Nov 2023 (SYZ) - change the optimal number of clusters to 6 in
#                     Sec. 6.2. Skip Sec. 10.7 for python graphics.
#  7 Nov 2023 (SYZ) - test Sec. 10.7.

TTR=${1:-"${HOME}/Tutorial"}
MDL=${2:-"${HOME}/hysplit"}
OUT=${3:-"${MDL}/testing"}
NCPU=${4:-1}			# number of CPUs for parallel execution

echo "TTR=${TTR}"
echo "MDL=${MDL}"
echo "OUT=${OUT}"

TTRSCR="${TTR}/bash"		# location of tutorial scripts

# Add the HYSPLIT tutorial location to environment variables
export TTR

function die() {
   echo "$*"
   exit 1
}

function hy_have_expected_files() {
   local section_no=$1

   local output_dir="${OUT}/Sec${section_no}"

   # check if all expected files already exist
   local not_there=0
   for f in ${EXPECTED_FILES[@]}; do
      if [ ! -e "${output_dir}/${f}" ]; then
         not_there=1
         break
      fi
   done

   # Return 0 if all files are there
   return ${not_there}
}

function hy_run() {
   local section_no=$1
   local script=$2

   local output_dir="${OUT}/Sec${section_no}"

   # check if all expected files already exist
   local not_there=0
   for f in ${EXPECTED_FILES[@]}; do
      if [ ! -e "${output_dir}/${f}" ]; then
         not_there=1
         break
      fi
   done

   # return if all expected files are there
   if [ ${not_there} -eq 0 ]; then
      echo "Sec. ${section_no} is skipped because output(s) exist: ${EXPECTED_FILES[@]}"
      return
   fi

   echo "Sec. ${section_no} started [`date`]"

   # create the output directory if necessary
   [ -d "${output_dir}" ] || mkdir -p "${output_dir}"

   # Note $1 and $2 are already used. Shifting arguments twice makes $*
   # to contain $3, $4, etc.
   shift; shift
   "${script}" "${MDL}" "${output_dir}" "NO" $* || die "ERROR: Sec. ${section_no} failed"
}

if [ ! -d "${OUT}" ]; then
   die "ERROR: output directory ${OUT} does not exist"
fi
cd "${OUT}"
 
