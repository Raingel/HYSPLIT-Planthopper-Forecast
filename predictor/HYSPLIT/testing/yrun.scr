hy_run "15.2" ${TTRSCR}/cust_fdnpp.sh "RP201103.bin"
 
#------------------------------------------------------------------------------
# Sec 15.3
EXPECTED_FILES=("dose012.png" "dose013.png")
hy_run "15.3" ${TTRSCR}/cust_dose.sh
 
#------------------------------------------------------------------------------
# Sec 16.1
EXPECTED_FILES=("volc009.png" "volc011.png")
hy_run "16.1" ${TTRSCR}/cust_volc.sh
 
#------------------------------------------------------------------------------
# Sec 16.2

EXPECTED_FILES=("part003.png" "part005.png")
if hy_have_expected_files "16.2"; then
   echo "Sec. 16.2 is skipped because output(s) exist: ${EXPECTED_FILES[@]}"
else
   # Copy SETUP.CFG, PARDUMP, and CONTROL1 from Sec. 16.1
   if [ -d "${OUT}/Sec16.1" ]; then
      [ -d "${OUT}/Sec16.2" ] || mkdir -p "${OUT}/Sec16.2"
      cp -f "${OUT}"/Sec16.1/SETUP.CFG "${OUT}/Sec16.2"
      cp -f "${OUT}"/Sec16.1/PARDUMP   "${OUT}/Sec16.2"
      cp -f "${OUT}"/Sec16.1/CONTROL1  "${OUT}/Sec16.2"
   fi

   hy_run "16.2" ${TTRSCR}/cust_pard.sh
fi
 
#------------------------------------------------------------------------------
# Sec 16.3

EXPECTED_FILES=("adj007.png" "adj006.png")
if hy_have_expected_files "16.3"; then
   echo "Sec. 16.3 is skipped because output(s) exist: ${EXPECTED_FILES[@]}"
else
   # Copy PARDUMP from Sec. 16.2
   if [ -d "${OUT}/Sec16.2" ]; then
      [ -d "${OUT}/Sec16.3" ] || mkdir -p "${OUT}/Sec16.3"
      cp -f "${OUT}"/Sec16.2/PARDUMP   "${OUT}/Sec16.3"
   fi

   hy_run "16.3" ${TTRSCR}/cust_toms.sh
fi

#------------------------------------------------------------------------------
# Sec 16.4
EXPECTED_FILES=("psize003.png" "psize007.png")
hy_run "16.4" ${TTRSCR}/cust_psize.sh
 
#------------------------------------------------------------------------------
# Sec 16.5
EXPECTED_FILES=("etime013.png" "etime014.png")
hy_run "16.5" ${TTRSCR}/cust_emit.sh

#------------------------------------------------------------------------------
# Sec 17.1
EXPECTED_FILES=("cntr005.png" "cntr006.png")
hy_run "17.1" ${TTRSCR}/src_cntr.sh
 
#------------------------------------------------------------------------------
# Sec 17.2
# Note no plots are generated.
EXPECTED_FILES=("LAGOUT.TXT")
hy_run "17.2" ${TTRSCR}/disp_dyn.sh
 
#------------------------------------------------------------------------------
# Sec 17.3
EXPECTED_FILES=("ratio004.png" "ratio005.png")
hy_run "17.3" ${TTRSCR}/chem_ratio.sh
 
#------------------------------------------------------------------------------
# Sec 17.4
EXPECTED_FILES=("sage010.png" "sage013.png")
hy_run "17.4" ${TTRSCR}/conc_local.sh
 
#------------------------------------------------------------------------------
# Sec 17.5
EXPECTED_FILES=("pole006.png")
hy_run "17.5" ${TTRSCR}/conc_pole.sh
 
echo "Run completed at `date`"
