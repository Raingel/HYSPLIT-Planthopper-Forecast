today=`date -u +%Y%m%d`
forecast_dir="/pub/forecast/${today}/"
forecast_file="hysplit.t00z.nama"
forecast_pathname="${forecast_dir}${forecast_file}"
if [ ! -f "${forecast_pathname}" ]; then
   echo "ERROR: no contour tests because of a missing file: ${forecast_pathname}"
else
   # ------------------------
   echo "Test 055 ..."

   strace ${PGM}contour "-D${forecast_dir}" "-F${forecast_file}" \
         -y40.000 -x-90.00 -c1 -VTEMP -a1 1> grun_055a1.log 2>&1
   verify_delete GIS_METEO_01.txt gistmp.txt

   strace ${PGM}contour "-D${forecast_dir}" "-F${forecast_file}" \
         -y40.000 -x-90.00 -c1 -VTEMP 1> grun_055.log 2>&1
   verify contour.ps
   mv contour.ps grun_055.ps
   cat grun_055.ps >>grun_all.ps

   # ------------------------
   echo "Test 056 ..."

   strace ${PGM}contour "-D${forecast_dir}" "-F${forecast_file}" \
         +g1 \
         -y40.000 -x-90.00 -c1 -VTEMP 1> grun_056.log 2>&1
   verify contour.html
   mv contour.html grun_056.html
   cat grun_056.html >>grun_all.html
fi

