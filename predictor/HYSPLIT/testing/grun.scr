echo "37.500 -90.000 LOC001"				 >STATIONPLOT.CFG
echo "MAPTEXT.CFG"					 >MAPTEXT.CFG
echo "LINE 2 NOT USED BY TRAJPLOT"			>>MAPTEXT.CFG
echo "SHOULD SEE 'LOC001' AT LAT 37.50 AND LON -90.000"	>>MAPTEXT.CFG

strace ${PGM}trajplot -itdump_001 -ogrun_001.ps -a1 1> grun_001a1.log 2>&1
verify_delete GIS_traj_ps_01.txt GIS_traj_ps_01.att

strace ${PGM}trajplot -itdump_001 -ogrun_001.ps -a3 1> grun_001a3.log 2>&1
verify_delete grun_001_01.kml

strace ${PGM}trajplot -itdump_001 -ogrun_001.ps 1> grun_001.log 2>&1
verify grun_001.ps
rm -f LABELS.CFG STATIONPLOT.CFG MAPTEXT.CFG TRAJ.CFG
cat grun_001.ps >grun_all.ps

