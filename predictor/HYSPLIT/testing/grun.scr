#!/bin/bash
#
# grun.scr - test the PROCESS option of HYSPLIT graphics programs.
#
# Change history:
# 21 Sep 2021 (SYZ) - initial
# 14 Oct 2021 (SYZ) - check the GIS option of CONTOUR.

export PGM=../exec/
export DEV=../exec/
export EXM=../examples/

rm -f grun_*.log grun_*.ps grun_*.html

function die() {
   local msg=$1
   echo "$msg"
   exit 1
}

function verify() {
   for arg; do
      fname=${arg}
      [ ! -f "${fname}" ] && echo "ERROR: file not found: ${fname}"
   done
}

function verify_delete() {
   for arg; do
      fname=${arg}
      verify "${fname}"
      if [ -f "${fname}" ]; then
         rm "${fname}"
      fi
   done
}

# -------------------------
