5.0
1
1
1
PRSS
8
-1
-1
0,0
!
   verify_delete GIS_METEO_01.txt gistmp.txt
   verify display.ps
   mv display.ps grun_059.ps
   cat grun_059.ps >>grun_all.ps

   # ------------------------
