today=`date -u +%Y%m%d`
today_day_of_month=`date -u +%d`
forecast_dir="/pub/forecast/${today}/"
forecast_file="hysplit.t00z.gfsf"
forecast_pathname="${forecast_dir}${forecast_file}"
if [ ! -f "${forecast_pathname}" ]; then
   echo "ERROR: no display tests because of a missing file: ${forecast_pathname}"
else
