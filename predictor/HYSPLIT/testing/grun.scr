mv stabplot.052.html grun_052.html
cat grun_052.html >>grun_all.html

rm -f LABELS.052

# ------------------------
if [ ! -f cmean ]; then
   cp CONTROL.026 CONTROL
   for f in 1 2 3 4 5 6 7 8 9; do
      ${PGM}hycs_ens ${f}
   done
   ${PGM}conprob -bcdump_026
fi

if [ ! -f datem_053.txt ]; then
   cat > datem_053.txt <<!
Mockup date for station 999
year mn dy  shr  dur   lat     lon    pmch  stn
1995 10 16 0000 0300 40.00  -90.00     0.0  999
1995 10 16 0300 0300 40.00  -90.00     0.0  999
1995 10 16 0600 0300 40.00  -90.00  1.6e-13 999
1995 10 16 0900 0300 40.00  -90.00  2.7e-12 999
1995 10 16 1200 0300 40.00  -90.00  3.8e-12 999
1995 10 16 1500 0300 40.00  -90.00  1.0e-12 999
1995 10 16 1800 0300 40.00  -90.00  6.6e-13 999
1995 10 16 2100 0300 40.00  -90.00  1.1e-14 999
1995 10 17 0000 0300 40.00  -90.00     0.0  999
!
fi

