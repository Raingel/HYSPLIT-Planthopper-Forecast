# ------------------------
today=`date -u +%Y%m%d`
forecast_dir="/pub/forecast/${today}/"
forecast_file="hysplit.t00z.nama"
forecast_pathname="${forecast_dir}${forecast_file}"
if [ ! -f "${forecast_pathname}" ]; then
   echo "ERROR: no showgrid tests because of a missing file: ${forecast_pathname}"
else
   # ------------------------
   echo "Test 045 ..."
   strace ${PGM}showgrid "-D${forecast_dir}" "-F${forecast_file}" \
         -Q35.00 -R-90.00 -S40.00 -T-85.0 -B \
         1> grun_045.log 2>& 1
   #verify_delete GRIDINFO.txt
   verify showgrid.ps
   mv showgrid.ps grun_045.ps
   cat grun_045.ps >>grun_all.ps

   rm -f WARNING MESSAGE

   # ------------------------
   echo "Test 046 ..."
   strace ${PGM}showgrid "-D${forecast_dir}" "-F${forecast_file}" \
         -P046 \
         -Q35.00 -R-90.00 -S40.00 -T-85.0 -B \
         1> grun_046.log 2>& 1
   #verify_delete GRIDINFO.046
   verify showgrid_046.ps
   mv showgrid_046.ps grun_046.ps
   cat grun_046.ps >>grun_all.ps

   rm -f WARNING MESSAGE

   # ------------------------
   echo "Test 047 ..."
   strace ${PGM}showgrid "-D${forecast_dir}" "-F${forecast_file}" \
         +g1 \
         -Q35.00 -R-90.00 -S40.00 -T-85.0 -B \
         1> grun_047.log 2>& 1
   #verify_delete GRIDINFO.txt
   verify showgrid.html
   mv showgrid.html grun_047.html
   cat grun_047.html >>grun_all.html

   rm -f WARNING MESSAGE

   # ------------------------
   echo "Test 048 ..."
   strace ${PGM}showgrid "-D${forecast_dir}" "-F${forecast_file}" \
         +g1 -P048 \
         -Q35.0 -R-90.00 -S40.00 -T-85.0 -B \
         1> grun_048.log 2>& 1
   #verify_delete GRIDINFO.048
   verify showgrid_048.html
   mv showgrid_048.html grun_048.html
   cat grun_048.html >>grun_all.html

   rm -f WARNING MESSAGE
fi

